                <zone forceUpdate='true' h='28500' id='38' type-v2='text' w='78500' x='84400' y='71250'>
                  <formatted-text>
                    <run bold='true' fontalignment='1' fontcolor='#1b1b1b' fontsize='18' underline='true'>Key Insights</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#1b1b1b' fontsize='15'>.Casual riders take longer trips on average compared to members.</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#1b1b1b' fontsize='15'>.Members show more consistent usage throughout the week.</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#1b1b1b' fontsize='15'>.Weekend demand is higher among casual riders.</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#1b1b1b' fontsize='15'>.Converting casual riders into members could increase long term</run>
                    <run bold='true' fontcolor='#1b1b1b' fontsize='11'>Æ </run>
                    <run bold='true' fontcolor='#1b1b1b' fontsize='15'>customer value</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
